# Force LF for all text files checked out on any OS
* text=auto eol=lf

# Explicitly LF for files that break when they have CRLF
*.sh        text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.properties text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.java      text eol=lf
*.md        text eol=lf
Dockerfile  text eol=lf

# Binary files - never touch line endings
*.jar       binary
*.class     binary
*.png       binary
*.jpg       binary
*.zip       binary
